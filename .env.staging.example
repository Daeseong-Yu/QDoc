APP_DOMAIN="example.com"
APP_URL="https://example.com"
APP_ENV="staging"
ALLOW_CONSOLE_OTP="true"

POSTGRES_DB="qdoc"
POSTGRES_USER="qdoc"
QDOC_DB_SECRET="replace-with-deploy-db-secret"
DATABASE_URL="postgresql://qdoc:replace-with-deploy-db-secret@postgres:5432/qdoc?schema=public"

REDIS_URL="redis://redis:6379"

SESSION_SECRET="replace-with-a-long-random-session-secret"
WORKER_POLL_INTERVAL_MS="5000"
WORKER_OUTBOX_BATCH_SIZE="10"
WORKER_OUTBOX_MAX_ATTEMPTS="5"
