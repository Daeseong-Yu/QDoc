generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Clinic {
  clinicId               Int           @id @default(autoincrement()) @map("ClinicID")
  name                   String?       @db.NVarChar(100) @map("Name")
  location               String?       @db.NVarChar(100) @map("Location")
  totalWaitCount         Int           @default(0) @map("TotalWaitCount")
  avgConsultTimeMinutes  Int           @default(7) @map("AvgConsultTimeMinutes")
  patientQueues          PatientQueue[]

  @@map("Clinics")
}

model PatientQueue {
  queueId      Int       @id @default(autoincrement()) @map("QueueID")
  clinicId     Int       @map("ClinicID")
  patientName  String?   @db.NVarChar(50) @map("PatientName")
  status       String?   @default("Waiting") @db.NVarChar(20) @map("Status")
  createdAt    DateTime  @default(now()) @db.DateTime @map("CreatedAt")
  clinic       Clinic    @relation(fields: [clinicId], references: [clinicId], onDelete: NoAction, onUpdate: NoAction)

  @@index([clinicId, status])
  @@index([patientName, status])
  @@map("PatientQueue")
}

model Notification {
  notificationId Int       @id @default(autoincrement()) @map("NotificationID")
  patientName    String?   @db.NVarChar(50) @map("PatientName")
  clinicId       Int?      @map("ClinicID")
  rank           Int?      @map("Rank")
  message        String?   @db.NVarChar(200) @map("Message")
  sentAt         DateTime  @default(now()) @db.DateTime @map("SentAt")
  isDelivered    Boolean   @default(false) @map("IsDelivered")

  @@index([clinicId, rank])
  @@map("Notifications")
}
