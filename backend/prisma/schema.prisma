generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Customer {
  id            String         @id @default(cuid()) @db.VarChar(64)
  authUserId    String?        @unique @db.VarChar(191)
  name          String         @db.NVarChar(100)
  phone         String?        @db.VarChar(32)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  familyMembers FamilyMember[]
  queueTickets  QueueTicket[]
}

model FamilyMember {
  id           String        @id @default(cuid()) @db.VarChar(64)
  customerId   String        @db.VarChar(64)
  name         String        @db.NVarChar(100)
  relationship String        @db.NVarChar(40)
  birthDate    DateTime?
  createdAt    DateTime      @default(now())
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  queueTickets QueueTicket[]
}

model Hospital {
  id            String             @id @db.VarChar(64)
  name          String             @db.NVarChar(120)
  address       String             @db.NVarChar(200)
  phone         String             @db.VarChar(32)
  lat           Float
  lng           Float
  queueStatus   String             @default("Open") @db.VarChar(20)
  avgMin        Int                @default(5)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  departments   Department[]
  queues        Queue[]
  waitSnapshots WaitTimeSnapshot[]
}

model Department {
  id         String   @id @db.VarChar(64)
  hospitalId String   @db.VarChar(64)
  name       String   @db.NVarChar(80)
  code       String?  @db.VarChar(20)
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  doctors    Doctor[]
  queues     Queue[]

  @@index([hospitalId, name])
}

model Doctor {
  id           String     @id @db.VarChar(64)
  departmentId String     @db.VarChar(64)
  name         String     @db.NVarChar(100)
  specialty    String?    @db.NVarChar(100)
  isAvailable  Boolean    @default(true)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([departmentId])
}

model Queue {
  id            String             @id @default(cuid()) @db.VarChar(64)
  hospitalId    String             @db.VarChar(64)
  departmentId  String?            @db.VarChar(64)
  status        String             @default("Open") @db.VarChar(20)
  avgMin        Int                @default(5)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  hospital      Hospital           @relation(fields: [hospitalId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  department    Department?        @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tickets       QueueTicket[]
  waitSnapshots WaitTimeSnapshot[]

  @@index([hospitalId, departmentId, status])
}

model QueueTicket {
  id               String            @id @default(cuid()) @db.VarChar(64)
  queueId          String            @db.VarChar(64)
  customerId       String            @db.VarChar(64)
  familyMemberId   String?           @db.VarChar(64)
  status           String            @default("Waiting") @db.VarChar(20)
  ticketNumber     Int
  cancelledReason  String?           @db.NVarChar(200)
  calledAt         DateTime?
  completedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  queue            Queue             @relation(fields: [queueId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  familyMember     FamilyMember?     @relation(fields: [familyMemberId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notificationLogs NotificationLog[]

  @@unique([queueId, ticketNumber])
  @@index([customerId, status])
  @@index([queueId, status])
}

model WaitTimeSnapshot {
  id             String   @id @default(cuid()) @db.VarChar(64)
  hospitalId     String   @db.VarChar(64)
  queueId        String?  @db.VarChar(64)
  source         String   @db.VarChar(40)
  averageMinutes Int
  waitingCount   Int
  capturedAt     DateTime @default(now())
  hospital       Hospital @relation(fields: [hospitalId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  queue          Queue?   @relation(fields: [queueId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([hospitalId, capturedAt])
}

model NotificationLog {
  id       String      @id @default(cuid()) @db.VarChar(64)
  ticketId String      @db.VarChar(64)
  stage    String      @db.VarChar(20)
  sentAt   DateTime    @default(now())
  ticket   QueueTicket @relation(fields: [ticketId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([ticketId, stage])
}

model SymptomAnalysisHistory {
  id                    String   @id @default(cuid()) @db.VarChar(64)
  customerId            String?  @db.VarChar(64)
  symptomText           String   @db.NVarChar(1000)
  urgencyLevel          String   @db.VarChar(20)
  recommendedDepartment String   @db.NVarChar(100)
  recommendation        String   @db.NVarChar(1000)
  confidence            Float
  createdAt             DateTime @default(now())
}
