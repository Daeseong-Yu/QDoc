{
  "name": "qdoc",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --filter @qdoc/web dev",
    "build": "pnpm --filter @qdoc/web build",
    "lint": "pnpm --filter @qdoc/web lint",
    "typecheck": "pnpm --filter @qdoc/web typecheck",
    "db:validate": "dotenv -e .env -- pnpm --filter @qdoc/db db:validate",
    "db:generate": "dotenv -e .env -- pnpm --filter @qdoc/db db:generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @qdoc/db db:migrate",
    "db:seed": "dotenv -e .env -- pnpm --filter @qdoc/db db:seed"
  },
  "devDependencies": {
    "@qdoc/config": "workspace:*",
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  }
}
