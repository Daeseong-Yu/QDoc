generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TicketStatus {
  waiting
  called
  in_service
  completed
  no_show
  cancelled
}

enum MembershipRole {
  staff
  admin
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  sites     Site[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Site {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  queues         Queue[]
  memberships    Membership[]
  tickets        Ticket[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Queue {
  id        String   @id @default(cuid())
  siteId    String
  name      String
  isOpen    Boolean  @default(true)
  site      Site     @relation(fields: [siteId], references: [id])
  tickets   Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId, createdAt])
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  memberships     Membership[]
  patientProfile  PatientProfile?
  otpChallenges   OtpChallenge[]
  tickets         Ticket[]
  auditLogs       AuditLog[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Membership {
  id        String         @id @default(cuid())
  userId    String
  siteId    String
  role      MembershipRole @default(staff)
  user      User           @relation(fields: [userId], references: [id])
  site      Site           @relation(fields: [siteId], references: [id])
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([userId, siteId])
}

model PatientProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String?
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OtpChallenge {
  id         String    @id @default(cuid())
  userId     String?
  email      String
  codeHash   String
  expiresAt  DateTime
  verifiedAt DateTime?
  user       User?     @relation(fields: [userId], references: [id])
  createdAt  DateTime  @default(now())
}

model Ticket {
  id          String            @id @default(cuid())
  siteId      String
  queueId     String
  userId      String
  status      TicketStatus      @default(waiting)
  site        Site              @relation(fields: [siteId], references: [id])
  queue       Queue             @relation(fields: [queueId], references: [id])
  user        User              @relation(fields: [userId], references: [id])
  events      TicketEvent[]
  notifications NotificationLog[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([siteId, status, createdAt])
  @@index([siteId, status, queueId, createdAt])
}

model TicketEvent {
  id        String       @id @default(cuid())
  ticketId  String
  status    TicketStatus
  note      String?
  ticket    Ticket       @relation(fields: [ticketId], references: [id])
  createdAt DateTime     @default(now())
}

model NotificationLog {
  id        String   @id @default(cuid())
  ticketId  String?
  channel   String
  message   String
  ticket    Ticket?  @relation(fields: [ticketId], references: [id])
  createdAt DateTime @default(now())
}

model Outbox {
  id          String    @id @default(cuid())
  type        String
  payload     Json
  status      String    @default("pending")
  attempts    Int       @default(0)
  availableAt DateTime  @default(now())
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, availableAt, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  metadata  Json?
  actor     User?    @relation(fields: [actorId], references: [id])
  createdAt DateTime @default(now())
}
